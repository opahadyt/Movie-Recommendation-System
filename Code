    font=("Arial", 12, "bold"),
    bg="#1db954",
    fg="white",
    padx=12,
    pady=4
)
recommend_button.grid(row=0, column=1, padx=8)

title_combo = ttk.Combobox(
    root,
    values=sorted(df["movie_name"].unique().tolist()),
    width=55,
    font=("Arial", 11)
